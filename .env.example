# Example environment (copy to `.env.local`)

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Postgres (migrations, webhooks, service paths)
DATABASE_URL=postgres://postgres:password@db.YOUR_PROJECT.supabase.co:5432/postgres

# libsodium secretbox master key (64 hex chars = 32 bytes)
SECRETS_KEY=012345abcdefghijklmnopqrstuvwxyzABCDEF0123456789abcdefghijkl

# Cron
CRON_SECRET=change_me

# Exact Online (Phase 3)
# Register an app in the Exact App Centre for the same region as your customers.
EXACT_CLIENT_ID=
EXACT_CLIENT_SECRET=
# Webhook HMAC secret from the app registration (used to verify `HashCode` on deliveries).
EXACT_WEBHOOK_SECRET=
# Public base URL of this deployment (OAuth redirect + webhook callback construction).
APP_BASE_URL=http://localhost:3000
# Optional: verbose outbound Exact HTTP logging to `sync_logs`
# EXACT_HTTP_SYNC_LOG=true

# Webhook development
# WEBHOOK_SKIP_SIGNATURE_VERIFY=true
# WEBHOOK_SIGNATURE_STUB_SECRET=
# NEXT_PUBLIC_APP_BASE_URL may be used as a fallback when APP_BASE_URL is unset
